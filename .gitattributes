# Normalize line endings: text files are LF in the repo and on checkout,
# so the Rust/C/Python lanes stay byte-identical across Windows/Linux/WSL.
* text=auto eol=lf

# Explicit source types (defensive; covered by the rule above).
*.rs   text eol=lf
*.c    text eol=lf
*.h    text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.txt  text eol=lf

# Binary assets must never be line-ending converted.
*.docx binary
*.png  binary
*.jpg  binary
*.pdf  binary
